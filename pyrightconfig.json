{
  "venvPath": ".",
  "venv": "venv",
  "pythonVersion": "3.11",
  "pythonPlatform": "Windows",
  "include": [
    "trinetra_ml",
    "trinetra_backend"
  ],
  "exclude": [
    "venv",
    "trinetra_frontend",
    "**/__pycache__"
  ],
  "extraPaths": [
    "trinetra_ml",
    "trinetra_backend"
  ],
  "reportMissingImports": "warning",
  "reportMissingModuleSource": "none",
  "reportOperatorIssue": "none",
  "reportIndexIssue": "none",
  "typeCheckingMode": "basic"
}
